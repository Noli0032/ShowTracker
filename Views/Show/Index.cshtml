@model TvShow[]

@{
    ViewData["Title"] = "Shows";
}

<div class = "container text-center">
    <div class = "row g-2">
        @foreach (var show in Model) 
        {
            <div class = "col-1">
                <div class = "card bg-dark">
                    <img class = "card-img-top img-fluid" src="@show.Image?.Medium" />
                </div>
            </div>
        }
    </div>
</div>